# LLM Configuration
# Option 1: Local LLM (Ollama - Recommended for M4 Mac Mini)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# Option 2: OpenAI API (Cloud-based, costs apply)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=your_openai_api_key_here

# Embeddings Configuration
# Option 1: Local embeddings (Ollama)
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# Option 2: OpenAI embeddings
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# GitHub
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USER=your_github_username

# Google Cloud
GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
GOOGLE_DRIVE_FOLDER_ID=your_shared_drive_folder_id

# Application Settings
LOG_LEVEL=INFO
READ_ONLY_MODE=true

# Fine-tuning Configuration
FINETUNING_ENABLED=false  # Set to true to enable real-time fine-tuning
FINETUNING_AUTO=false  # Auto fine-tune after interactions (or require manual trigger)
FINETUNING_LR=1e-5  # Learning rate for fine-tuning
FINETUNING_STEPS=100  # Steps per fine-tuning session
FINETUNING_BUFFER_SIZE=100  # Number of recent messages to keep for training
FINETUNING_BACKEND=ane  # ane (Apple Neural Engine), cpu, or cuda
FINETUNING_CHECKPOINT_DIR=./checkpoints  # Where to save model checkpoints
FINETUNING_MAX_CHECKPOINTS=10  # Maximum number of checkpoints to keep

# Fine-tuning Safety Controls
FINETUNING_REQUIRE_APPROVAL=true  # Require user approval before fine-tuning
FINETUNING_CONTENT_FILTER=true  # Filter unsafe content from training data
FINETUNING_ROLLBACK=true  # Enable checkpoint rollback

# Security
MAX_TOKENS=4096
ALLOWED_REPOS=repo1,repo2,repo3
ALLOWED_DRIVE_FOLDERS=folder_id1,folder_id2
